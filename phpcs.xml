<?xml version="1.0"?>
<ruleset name="ConfidUp">
  <description>PHPCS ruleset for ConfidUp WordPress theme and plugin.</description>

  <!-- Files to check -->
  <file>wp-content/themes/confidup</file>
  <file>wp-content/plugins/confidup-core</file>

  <!-- Exclusions -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>

  <!-- Standards -->
  <rule ref="WordPress">
    <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
  </rule>

  <!-- PHP version -->
  <config name="minimum_supported_wp_version" value="6.4" />
  <config name="testVersion" value="8.1-" />
</ruleset>
