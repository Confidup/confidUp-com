{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0057FF",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#00C48C",
          "name": "Secondary"
        },
        {
          "slug": "dark",
          "color": "#0D0D0D",
          "name": "Dark"
        },
        {
          "slug": "light",
          "color": "#F5F5F5",
          "name": "Light"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Inter, system-ui, -apple-system, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "sm",   "size": "0.875rem", "name": "Small",  "fluid": false },
        { "slug": "base", "size": "1rem",     "name": "Base",   "fluid": false },
        { "slug": "md",   "size": "1.25rem",  "name": "Medium", "fluid": { "min": "1.1rem",  "max": "1.25rem" } },
        { "slug": "lg",   "size": "1.5rem",   "name": "Large",  "fluid": { "min": "1.25rem", "max": "1.5rem"  } },
        { "slug": "xl",   "size": "2rem",     "name": "XL",     "fluid": { "min": "1.5rem",  "max": "2rem"    } },
        { "slug": "2xl",  "size": "3rem",     "name": "2XL",    "fluid": { "min": "1.75rem", "max": "3rem"    } },
        { "slug": "3xl",  "size": "4rem",     "name": "3XL",    "fluid": { "min": "2rem",    "max": "4rem"    } }
      ]
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--dark)"
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-full-width", "title": "Full Width Page", "postTypes": ["page"] },
    { "name": "page-services", "title": "Services Page", "postTypes": ["page"] },
    { "name": "page-pricing", "title": "Pricing Page", "postTypes": ["page"] },
    { "name": "page-about", "title": "About Us Page", "postTypes": ["page"] },
    { "name": "page-contact", "title": "Contact Us Page", "postTypes": ["page"] },
    { "name": "page-blog", "title": "Blog Page", "postTypes": ["page"] },
    { "name": "page-case-studies", "title": "Case Studies Page", "postTypes": ["page"] },
    { "name": "page-testimonials", "title": "Testimonials Page", "postTypes": ["page"] },
    { "name": "page-faq", "title": "FAQ Page", "postTypes": ["page"] },
    { "name": "page-privacy-policy", "title": "Privacy Policy Page", "postTypes": ["page"] },
    { "name": "page-terms", "title": "Terms & Conditions Page", "postTypes": ["page"] },
    { "name": "page-cookie-policy", "title": "Cookie Policy Page", "postTypes": ["page"] }
  ]
}
